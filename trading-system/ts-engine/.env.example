# DEX 配置
DEX_PROVIDER=lighter
DEX=lighter
DEX_ENV=mainnet

# Lighter DEX 配置 (mainnet)
LIGHTER_API_KEY_INDEX=7
LIGHTER_API_PUBLIC_KEY=your-public-key-here
LIGHTER_API_PRIVATE_KEY=your-private-key-here
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_ACCOUNT_INDEX=your-account-index
WALLET_ADDRESS=0x-your-wallet-address

# 交易对（逗号分隔）
SYMBOLS=BTC_USDT_Perp,ETH_USDT_Perp

# Redis
REDIS_URL=redis://localhost:6379

# SQLite
SQLITE_PATH=/data/trades.db

# gRPC
GRPC_PORT=50051
# gRPC TLS - set to 'true' to enable mutual TLS (requires cert files)
# GRPC_TLS_ENABLED=false
# GRPC_TLS_KEY_PATH=/app/certs/server.key
# GRPC_TLS_CERT_PATH=/app/certs/server.crt

# Tailscale
TAILSCALE_AI_IP=127.0.0.1

# 风控
MAX_POSITION_SIZE=0.003
MAX_DAILY_LOSS=20
MAX_CONCURRENT_SIGNALS=2
MIN_CONFIDENCE=60.0
MAX_PRICE_DEVIATION_PCT=0.5
SIGNAL_TTL_MS=300000
MARGIN_WARNING_THRESHOLD=0.7
MARGIN_CRITICAL_THRESHOLD=0.9
PAPER_TRADING=true

# Dashboard 安全
# DASHBOARD_TOKEN - 生产环境建议设置随机字符串
# DASHBOARD_TOKEN=change-me-to-a-random-token
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPM=60

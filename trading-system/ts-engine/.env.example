# Hyperliquid 测试网配置
PRIVATE_KEY=0x-your-evm-private-key
DEX=hyperliquid
DEX_ENV=testnet

# 交易对（逗号分隔）
SYMBOLS=BTC_USDT_Perp,ETH_USDT_Perp

# Redis
REDIS_URL=redis://localhost:6379

# SQLite
SQLITE_PATH=/data/trades.db

# gRPC
GRPC_PORT=50051
# gRPC TLS - set to 'true' to enable mutual TLS (requires cert files)
# GRPC_TLS_ENABLED=false
# GRPC_TLS_KEY_PATH=/app/certs/server.key
# GRPC_TLS_CERT_PATH=/app/certs/server.crt

# Tailscale
TAILSCALE_AI_IP=127.0.0.1

# 风控
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=500
MAX_CONCURRENT_SIGNALS=3
MIN_CONFIDENCE=60.0
MAX_PRICE_DEVIATION_PCT=0.5
SIGNAL_TTL_MS=300000
MARGIN_WARNING_THRESHOLD=0.7
MARGIN_CRITICAL_THRESHOLD=0.9

# Dashboard 安全
# DASHBOARD_TOKEN - 生产环境建议设置随机字符串，API 路由将通过 Bearer Token 鉴权
# DASHBOARD_TOKEN=change-me-to-a-random-token
# CORS_ORIGINS - 限允许的跨域来源，生产环境建议设为具体的 dashboard 域名
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPM=60

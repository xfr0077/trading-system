# GRVT 测试网配置
GRVT_API_KEY=your-api-key
GRVT_API_SECRET=0x-your-private-key
GRVT_TRADING_ACCOUNT_ID=your-trading-account-id
GRVT_ENV=testnet

# 交易对（逗号分隔）
SYMBOLS=BTC_USDT_Perp,ETH_USDT_Perp

# Redis
REDIS_URL=redis://localhost:6379

# SQLite
SQLITE_PATH=/data/trades.db

# gRPC
GRPC_PORT=50051

# Tailscale
TAILSCALE_AI_IP=127.0.0.1

# 风控
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=500
MAX_CONCURRENT_SIGNALS=3
MIN_CONFIDENCE=60.0
MAX_PRICE_DEVIATION_PCT=0.5
SIGNAL_TTL_MS=300000
MARGIN_WARNING_THRESHOLD=0.7
MARGIN_CRITICAL_THRESHOLD=0.9

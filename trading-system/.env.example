# DEX 配置
# PRIVATE_KEY: EVM 钱包私钥，用于 Hyperliquid 签名
PRIVATE_KEY=your-evm-private-key-here
# DEX: 交易所选择，可选值: hyperliquid（默认）| grvt
DEX=hyperliquid
# DEX_ENV: 运行环境，可选值: testnet（测试网，默认）| production（主网）
DEX_ENV=testnet

# Tailscale 配置
# TAILSCALE_AI_IP: 本地 AI 服务的 Tailscale IP 地址，格式如 100.x.x.x
# 可通过 `tailscale status` 查看目标设备的 Tailscale IP
TAILSCALE_AI_IP=100.x.x.x

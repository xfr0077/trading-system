# DEX 配置
# DEX_PROVIDER: 交易所选择，当前使用 lighter
DEX_PROVIDER=lighter
# DEX_ENV: 运行环境，可选值: testnet | mainnet
DEX_ENV=mainnet

# Lighter DEX 配置 (mainnet)
# 从 Lighter Dashboard 获取
LIGHTER_API_KEY_INDEX=7
LIGHTER_API_PUBLIC_KEY=your-public-key-here
LIGHTER_API_PRIVATE_KEY=your-private-key-here
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_ACCOUNT_INDEX=your-account-index
WALLET_ADDRESS=0x-your-wallet-address

# 交易对（逗号分隔）
SYMBOLS=BTC_USDT_Perp,ETH_USDT_Perp

# Redis
REDIS_URL=redis://localhost:6379

# SQLite
SQLITE_PATH=trades.db

# gRPC
GRPC_PORT=50051

# Tailscale (本地 AI 开发时使用)
TAILSCALE_AI_IP=127.0.0.1

# 风控参数
MAX_POSITION_SIZE=0.003    # 单笔最大仓位
MAX_DAILY_LOSS=20          # 每日最大亏损 ($)
MAX_CONCURRENT_SIGNALS=2   # 最大并发信号
MIN_CONFIDENCE=60.0        # 最低置信度阈值
MAX_PRICE_DEVIATION_PCT=0.5
SIGNAL_TTL_MS=300000
MARGIN_WARNING_THRESHOLD=0.7
MARGIN_CRITICAL_THRESHOLD=0.9

# Dashboard 安全
# DASHBOARD_TOKEN - 生产环境建议设置随机字符串
DASHBOARD_TOKEN=
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPM=60

# 交易模式
PAPER_TRADING=true

# AI 信号参数
STOP_LOSS_PCT=0.98       # 做多止损
TAKE_PROFIT_PCT=1.02     # 做多止盈

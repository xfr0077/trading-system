# GRVT API 配置
# GRVT_API_KEY: GRVT 交易所 API 密钥，从 https://app.grvt.io 获取
GRVT_API_KEY=your-api-key-here

# GRVT_ENV: 运行环境，可选值: testnet（测试网，默认）| mainnet（主网）
GRVT_ENV=testnet

# Tailscale 配置
# TAILSCALE_AI_IP: 本地 AI 服务的 Tailscale IP 地址，格式如 100.x.x.x
# 可通过 `tailscale status` 查看目标设备的 Tailscale IP
TAILSCALE_AI_IP=100.x.x.x

# DEX Provider Selection (lighter | ostium)
DEX_PROVIDER=lighter
DEX_ENV=mainnet

# Lighter Configuration (mainnet)
LIGHTER_API_KEY_INDEX=7
LIGHTER_API_PUBLIC_KEY=your_lighter_api_public_key
LIGHTER_API_PRIVATE_KEY=your_lighter_api_private_key
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
WALLET_ADDRESS=your_wallet_address
LIGHTER_ACCOUNT_INDEX=725539

# Redis (unchanged)
REDIS_URL=redis://redis:6379

# Risk Parameters (tighter for mainnet — real funds)
MAX_POSITION_SIZE=0.003
MAX_CONCURRENT_SIGNALS=2
MIN_CONFIDENCE=60
MAX_PRICE_DEVIATION_PCT=0.5
MAX_DAILY_LOSS=20
SIGNAL_TTL_MS=300000
MARGIN_WARNING_THRESHOLD=0.7
MARGIN_CRITICAL_THRESHOLD=0.9

# gRPC
GRPC_PORT=50051
# GRPC_TLS_ENABLED=true

# Dashboard
DASHBOARD_PORT=80
# DASHBOARD_TOKEN=set-a-random-token-here
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPM=60
SQLITE_PATH=/data/trades.db
SYMBOLS=BTC_USDT_Perp,ETH_USDT_Perp

# AI Signal Parameters
STOP_LOSS_PCT=0.98
TAKE_PROFIT_PCT=1.02

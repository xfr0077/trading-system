# Hyperliquid Mainnet Configuration
PRIVATE_KEY=your_evm_wallet_private_key
DEX_ENV=production
DEX=hyperliquid

# Redis (unchanged)
REDIS_URL=redis://redis:6379

# Risk Parameters (tighter for mainnet — real funds)
MAX_POSITION_SIZE=0.05
MAX_CONCURRENT_SIGNALS=2
MIN_CONFIDENCE=75
MAX_PRICE_DEVIATION_PCT=0.3
MAX_DAILY_LOSS=200
SIGNAL_TTL_MS=120000
MARGIN_WARNING_THRESHOLD=0.6
MARGIN_CRITICAL_THRESHOLD=0.8

# gRPC
GRPC_PORT=50051
# GRPC_TLS_ENABLED=true

# Dashboard
DASHBOARD_PORT=3000
# DASHBOARD_TOKEN=set-a-random-token-here
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPM=30
SQLITE_PATH=/data/trades.db
SYMBOLS=BTC_USDT_Perp,ETH_USDT_Perp

# TS Engine gRPC 地址
# TS_ENGINE_GRPC_URL: TS Engine 的 gRPC 服务地址，格式为 host:port
# 如果 TS Engine 在 VPS 上，使用其 Tailscale IP，如 100.x.x.x:50051
# 本地开发可使用 localhost:50051
TS_ENGINE_GRPC_URL=localhost:50051

# ONNX 模型路径
# MODEL_PATH: ONNX 模型文件路径，相对于 python-ai 目录
MODEL_PATH=models/model.onnx

# 特征窗口大小
# FEATURE_WINDOW: K 线特征窗口大小，用于计算技术指标
FEATURE_WINDOW=100

# 置信度阈值
# CONFIDENCE_THRESHOLD: 最低置信度阈值（0-100），低于此值的信号不会发送
CONFIDENCE_THRESHOLD=55.0

# 仓位大小
# POSITION_SIZE: 每次交易的仓位大小（占总资金比例）
POSITION_SIZE=0.01

# 最大滑点
# MAX_SLIPPAGE_BPS: 最大可接受滑点（基点，1 bps = 0.01%）
MAX_SLIPPAGE_BPS=10
